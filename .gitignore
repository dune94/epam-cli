# Dependencies
node_modules/

# Build output
dist/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
/logs/

# Orchestration logs (dynamic — all runtime artifacts)
orchestrations/logs/*.jsonl
orchestrations/logs/*.lock
orchestrations/logs/phase-improvements/
orchestrations/logs/claude_outputs/
orchestrations/logs/agent-status.json
orchestrations/logs/calibration.json
orchestrations/logs/quality-summary.json
orchestrations/logs/progress.txt
orchestrations/logs/messages/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/
.nyc_output/

# epam credentials (never commit)
.epam/.credentials
.epam/sessions/

# TypeScript cache
*.tsbuildinfo

# Orchestration runtime artifacts (generated per run — never commit)
orchestrations/*.before-cpa
orchestrations/*.before-*
orchestrations/*.pre-assessment
orchestrations/*.lock
orchestrations/review/

# CPA review logs (dynamic — generated per run)
orchestrations/logs/cpa-review.jsonl

# Dashboards build artifacts (generated by Eleventy)
orchestrations/dashboards/live/
orchestrations/dashboards/.cache/

# Generated project dashboards (written by dashboard-orchestrator-agent)
orchestrations/dashboards/live/dashboard/

# Python virtual environment
orchestrations/scripts/.venv/
.venv/

# Local Claude settings
.claude/settings.local.json

# Generated lifecycle/spec reports and message queues
orchestrations/logs/sdk-lifecycle-report.*
orchestrations/logs/spec-baseline.json
orchestrations/logs/spec-run-latest.json
orchestrations/logs/spec-summary.json
orchestrations/logs/spec-runs/
