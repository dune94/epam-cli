{
  "name": "epam-cli",
  "version": "0.1.0",
  "description": "Interactive AI coding assistant CLI",
  "main": "dist/epam.js",
  "bin": {
    "epam": "./dist/epam.js",
    "epam-cli": "./dist/epam.js"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "dashboards:build": "npx @11ty/eleventy --config orchestrations/dashboards/.eleventy.js",
    "dashboards:watch": "npx @11ty/eleventy --watch --config orchestrations/dashboards/.eleventy.js",
    "dashboards:serve": "npx @11ty/eleventy --serve --watch --config orchestrations/dashboards/.eleventy.js",
    "specification:run": "node orchestrations/scripts/spec-mode-runner.js"
  },
  "keywords": [
    "ai",
    "cli",
    "coding-assistant",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google/generative-ai": "^0.21.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "execa": "^9.5.1",
    "glob": "^11.0.0",
    "ioredis": "^5.10.0",
    "jose": "^5.9.6",
    "keytar": "^7.9.0",
    "marked": "^15.0.4",
    "marked-terminal": "^7.2.0",
    "open": "^10.1.0",
    "openai": "^4.77.0",
    "ora": "^8.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prompts": "^2.4.2",
    "ulid": "^2.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "@11ty/eleventy": "^3.1.2",
    "msw": "^2.7.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
